{% extends 'base.html.twig' %}

{% block title %}LinkCollection{% endblock %}

{% block body %}
    <h1>LinkCollection</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ link_collection.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ link_collection.name }}</td>
            </tr>
            <tr>
                <th>Public</th>
                <td>{{ link_collection.public ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_link_collection_index') }}">back to list</a>

    <a href="{{ path('app_link_collection_edit', {'id': link_collection.id}) }}">edit</a>

    {{ include('link_collection/_delete_form.html.twig') }}
{% endblock %}
